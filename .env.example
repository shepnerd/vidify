# .env.example — Cluster-specific configuration for Vidify
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# These env vars are read by scripts/rl.sh, scripts/run_test_gpu.sh,
# and agent/extensions/utils/serving.py

# ── Quota Group ──────────────────────────────────────────────────────────────
# Your GPU cluster quota group (required for rlaunch jobs)
RL_CHARGED_GROUP=my_gpu_group

# ── Private Machine ──────────────────────────────────────────────────────────
# RL_PRIVATE_MACHINE=group

# ── GPFS Mounts ──────────────────────────────────────────────────────────────
# Comma-separated mount points for GPU nodes.
# Must include:
#   1. Your project storage (for code, cache, models)
#   2. Shared public storage (for CUDA toolkit — needed by flashinfer JIT)
RL_MOUNT=gpfs://gpfs2/<your-path>:/mnt/shared-storage-gpfs2/<your-path>,gpfs://gpfs2/gpfs2-shared-public:/mnt/shared-storage-gpfs2/gpfs2-shared-public

# ── CUDA Toolkit ─────────────────────────────────────────────────────────────
# Path to shared CUDA toolkit on GPFS (GPU nodes have no internet for conda/pip).
# Required for Qwen3.5: flashinfer JIT-compiles GDN kernels and needs nvcc.
# Available versions: ls /mnt/shared-storage-gpfs2/gpfs2-shared-public/soft/cuda/
CUDA_HOME=/mnt/shared-storage-gpfs2/gpfs2-shared-public/soft/cuda/12.8
