# Vidify runtime configuration
# Copy to .env and adjust for your local deployment:
#   cp .env.example .env

LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=qwen3.5-9b

EMBED_BASE_URL=http://localhost:8000/v1
EMBED_MODEL=qwen-embed

CACHE_ROOT=./cache

# Optional Docker/vLLM defaults
VIDIFY_MODEL_DIR=./models
VIDIFY_VLLM_MODEL=/models/qwen3.5-9b
VIDIFY_VLLM_PORT=8000
